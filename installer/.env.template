# Homelab Environment Configuration Template
# Copy this file to ~/homelab/.env and customize for your setup

# Repository Configuration
#INSTALLER_REPO=https://github.com/razumnyak/homelab
#INSTALLER_BRANCH=main
#GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
#GITHUB_KEYS_URL=https://github.com/razumnyak.keys

# Node Configuration
#NODE_TYPE=master-node
#NODE_NAME=homelab-master
#MASTER_IP=192.168.1.150
#CLUSTER_TOKEN=

# Network Interfaces (run 'ip addr' to see available interfaces)
#WAN_INTERFACE=eth0
#LAN_INTERFACE=eth1

# Network Configuration
#LAN_SUBNET=10.0.0.0/24
#DHCP_RANGE_START=10.0.0.51
#DHCP_RANGE_END=10.0.0.250
#DNS_UPSTREAM=1.1.1.1,1.0.0.1

# Service IPs
#PI_HOLE_IP=10.0.0.2
#TRAEFIK_IP=10.0.0.3
#ARGOCD_IP=10.0.0.4
#METALLB_RANGE=10.0.0.10-10.0.0.50

# Service Credentials
#SERVICE_USERNAME=mozg
#PIHOLE_PASSWORD=
#ARGOCD_PASSWORD=
#TRAEFIK_PASSWORD=

# Installation Options
#SKIP_CLEANUP=false
#FORCE_CLEANUP=false
#SKIP_PREREQUISITES=false
#AUTO_CONFIRM=false
#VERBOSE_MODE=false

# K3s Configuration
#K3S_VERSION=stable
#K3S_EXTRA_ARGS=
#K3S_AGENT_ARGS=
#DISABLE_TRAEFIK=true
#DISABLE_SERVICELB=true

# System Configuration
#DEFAULT_TIMEZONE=UTC
#SSH_PORT=22
#K3S_API_PORT=6443
#KUBELET_PORT=10250

# Performance Tuning
#MAX_FILE_DESCRIPTORS=655350
#INOTIFY_WATCHES=524288
#VM_SWAPPINESS=10
#NET_SOMAXCONN=65535
#TCP_SYN_BACKLOG=65535
#NETDEV_BACKLOG=65535

# SSH Key Management
#ENABLE_SSH_KEY_SYNC=true
#GITHUB_KEYS_URL=https://github.com/razumnyak.keys
#SSH_KEY_SYNC_HOUR=3

# Cron Configuration
#ENABLE_AUTO_BACKUP=true
#BACKUP_RETENTION_DAYS=7
#ENABLE_SYSTEM_UPDATES=false